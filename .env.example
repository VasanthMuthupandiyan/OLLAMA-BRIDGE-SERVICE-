# Server Port configuration
PORT=7483

# Mandatory Bridge API Key required by clients in the X-API-KEY header
BRIDGE_API_KEY=<seacret-key>

# Base URL for the local Ollama instance
OLLAMA_BASE_URL=http://localhost:11434

# Default Models configured for Chat and Embeddings
OLLAMA_CHAT_MODEL=gemma2:2b
OLLAMA_EMBEDDING_MODEL=embeddinggemma

# API Timeouts
OLLAMA_TIMEOUT_CONNECT=10s
OLLAMA_TIMEOUT_READ=10s